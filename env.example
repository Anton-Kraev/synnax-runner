# Telegram Bot Token
# Получите токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=<tg-bot-token>

# Время выполнения скриптов (в формате cron)
# По умолчанию: каждый день в 6:00 UTC
CRON_SCHEDULE=0 6 * * *

# Таймаут выполнения скриптов (в секундах)
# По умолчанию: 5 минут
SCRIPT_TIMEOUT=300

# Путь к Python из venv (для .py и .ipynb; jupyter вызывается как python -m jupyter)
# Пример: .venv/bin/python3 или /path/to/project/.venv/bin/python3
# PYTHON_PATH=.venv/bin/python3
